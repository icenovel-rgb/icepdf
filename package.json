{
  "name": "icepdf",
  "version": "1.3.0",
  "description": "아크로벳 리더 스타일 PDF 뷰어/에디터 — 한글(HWPX)/Markdown 변환 내장",
  "main": "./out/main/index.js",
  "type": "module",
  "author": "icenovel",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "spike": "node spike/engine-spike.mjs",
    "dist": "electron-vite build && electron-builder --win --publish never"
  },
  "dependencies": {
    "kordoc": "^3.0.1",
    "mupdf": "^1.27.0",
    "pdfjs-dist": "4.10.38",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "playwright-core": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "zustand": "^5.0.14"
  }
}
